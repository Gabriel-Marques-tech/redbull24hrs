<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estatísticas — <%= evento.title %></title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/equipe.css">
    <link rel="stylesheet" href="/css/estatisticas-evento.css">
</head>
<body>
    <div class="barra-gradiente"></div>

    <a href="/home" class="cancelar">
        <img src="/assets/competição/Seta.svg" alt="">
        Voltar
    </a>

    <main>
        <aside class="etapas">
            <h3>Competição</h3>
            <div class="etapa ativa"><span>1</span><p>Estatísticas</p></div>
        </aside>

        <section class="conteudo conteudo-stats">
            <%
                const statusLabel = { in_progress: 'Em andamento', finished: 'Finalizada' };
                const statusClass = { in_progress: 'badge-in_progress', finished: 'badge-finished' };
                const dataFmt = evento.date
                    ? new Date(evento.date).toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' })
                    : '—';
                const startedAtIso = evento.started_at ? new Date(evento.started_at).toISOString() : '';
                const tvTotalKm = Number(dashboardStats.totalKm || 0);
                const tvParticipantCount = Array.isArray(athleteStats) ? athleteStats.length : 0;
            %>

            <div class="stats-topo">
                <div class="stats-topo-info">
                    <span class="badge-status <%= statusClass[evento.status] || 'badge-finished' %>">
                        <%= statusLabel[evento.status] || evento.status %>
                    </span>
                    <div class="stats-titulo-linha">
                        <h1><%= evento.title %></h1>
                        <div class="stats-acoes-topo">
                            <button type="button" class="btn-exportar" onclick="exportarPlanilha(<%= evento.id %>)">
                                <img src="/assets/estatisticas/compartilhar.svg" alt="" class="btn-exportar-icone">
                                Compartilhar como planilha
                            </button>
                        </div>
                    </div>
                    <div class="stats-meta">
                        <span><img src="/assets/estatisticas/mapa.svg" alt="" class="meta-icone"> <%= evento.local %></span>
                        <span><img src="/assets/estatisticas/calendario.svg" alt="" class="meta-icone"> <%= dataFmt %></span>
                    </div>
                </div>
            </div>

            <% if (evento.status === 'in_progress') { %>
            <div class="stats-barra-acao">
                <div class="countdown-bloco">
                    <span class="countdown-label">Tempo restante</span>
                    <span class="countdown-timer" id="countdown">--:--:--</span>
                </div>
                <% if (user_role === 'manager') { %>
                <div class="stats-barra-botoes">
                    <button type="button" class="btn-modo-tv" id="btnAbrirModoTv" title="Configurar Exibição Pública">
                        <span class="btn-modo-tv-icone" aria-hidden="true"></span>
                        Modo TV
                    </button>
                    <button type="button" class="btn-finalizar" onclick="finalizarCompetição(<%= evento.id %>)">
                        Finalizar competição
                    </button>
                </div>
                <% } %>
            </div>
            <% } %>

            <div class="stats-tabs">
                <button class="tab tab-ativa" data-tab="geral">Geral</button>
                <button class="tab" data-tab="dashboard">Dashboard</button>
                <button class="tab" data-tab="historico">Histórico de Auditoria</button>
                <button class="tab" data-tab="equipes">Equipes</button>
            </div>

            <!-- TAB GERAL -->
            <div class="tab-conteudo" id="tab-geral">
                <% teamStats.forEach((team, i) => {
                    const km = Number(team.total_km).toFixed(1);
                    const ps = Number(team.avg_pace_seconds);
                    const pace = ps > 0
                        ? Math.floor(ps / 60) + ':' + String(Math.round(ps % 60)).padStart(2, '0')
                        : '—';
                    const speed = team.avg_speed ? team.avg_speed + ' km/h' : '—';
                    const shifts = Number(team.shift_count);
                    const isLider = i === 0 && Number(team.total_km) > 0;
                %>
                <div class="team-stat-card">
                    <div class="team-stat-header <%= isLider ? 'lider' : '' %>">
                        <span class="team-stat-nome"><%= team.name %></span>
                        <% if (isLider) { %>
                        <span class="lider-badge">1°</span>
                        <% } %>
                    </div>
                    <div class="team-stat-body">
                        <div class="stat-item">
                            <img src="/assets/estatisticas/tênis.svg" alt="" class="stat-icone">
                            <div class="stat-info">
                                <span class="stat-valor"><%= km %></span>
                                <span class="stat-label">Quilometragem total</span>
                            </div>
                        </div>
                        <div class="stat-item">
                            <img src="/assets/estatisticas/relogio.svg" alt="" class="stat-icone">
                            <div class="stat-info">
                                <span class="stat-valor"><%= pace %></span>
                                <span class="stat-label">Pace médio</span>
                            </div>
                        </div>
                        <div class="stat-item">
                            <img src="/assets/estatisticas/corredor.svg" alt="" class="stat-icone">
                            <div class="stat-info">
                                <span class="stat-valor"><%= speed %></span>
                                <span class="stat-label">Velocidade média</span>
                            </div>
                        </div>
                        <div class="stat-item">
                            <img src="/assets/estatisticas/controle.svg" alt="" class="stat-icone">
                            <div class="stat-info">
                                <span class="stat-valor"><%= shifts %></span>
                                <span class="stat-label">Turnos registrados</span>
                            </div>
                        </div>
                        <div class="stat-item stat-item-destaque">
                            <img src="/assets/visao-geral/pessoas.svg" alt="" class="stat-icone">
                            <div class="stat-info">
                                <span class="stat-valor stat-atleta"><%= team.top_athlete %></span>
                                <span class="stat-label">Atleta destaque</span>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
                <% if (!teamStats || teamStats.length === 0) { %>
                <p class="stats-vazio">Nenhum dado disponível ainda.</p>
                <% } %>
            </div>

            <!-- TAB DASHBOARD -->
            <div class="tab-conteudo tab-oculto" id="tab-dashboard">
                <%
                    const ds = dashboardStats;
                    const periodos = ['Madrugada', 'Manhã', 'Tarde', 'Noite'];
                    const periodoIcone = { 'Madrugada': '🌙', 'Manhã': '🌅', 'Tarde': '☀️', 'Noite': '🌆' };
                    const kmByHourJson = JSON.stringify(ds.kmByHour);
                %>

                <!-- KPIs de topo -->
                <div class="dash-kpis">
                    <div class="dash-kpi dash-kpi-destaque">
                        <span class="dash-kpi-label"><%= evento.status === 'finished' ? 'Total percorrido' : 'Previsão de km ao fim' %></span>
                        <span class="dash-kpi-valor"><%= ds.projectedKm != null ? ds.projectedKm : '—' %> <span class="dash-kpi-unit">km</span></span>
                        <% if (evento.status === 'in_progress') { %>
                        <span class="dash-kpi-sub">Taxa atual: <%= ds.rateKmH != null ? ds.rateKmH + ' km/h' : '—' %> · <%= ds.elapsedHours != null ? ds.elapsedHours + 'h' : '—' %> decorridas</span>
                        <% } else { %>
                        <span class="dash-kpi-sub">Evento finalizado · <%= ds.elapsedHours != null ? ds.elapsedHours + 'h' : '—' %> de duração</span>
                        <% } %>
                    </div>
                    <div class="dash-kpi">
                        <span class="dash-kpi-label">Km percorridos</span>
                        <span class="dash-kpi-valor"><%= Number(ds.totalKm).toFixed(1) %> <span class="dash-kpi-unit">km</span></span>
                        <span class="dash-kpi-sub"><%= ds.elapsedHours != null ? Math.min(100, Math.round((ds.elapsedHours / 24) * 100)) + '%' : '—' %> do evento concluído</span>
                    </div>
                    <% if (ds.topShifts && ds.topShifts.length > 0) {
                        const best = ds.topShifts[0];
                        const dur = best.duration_seconds
                            ? Math.floor(best.duration_seconds/3600)+'h '+(Math.floor((best.duration_seconds%3600)/60))+'min'
                            : '—';
                    %>
                    <div class="dash-kpi">
                        <span class="dash-kpi-label">Maior turno</span>
                        <span class="dash-kpi-valor"><%= Number(best.distance).toFixed(1) %> <span class="dash-kpi-unit">km</span></span>
                        <span class="dash-kpi-sub"><%= best.athlete_name %> · <%= dur %></span>
                    </div>
                    <% } %>
                </div>

                <!-- Gráfico: km acumulado por equipe ao longo do evento -->
                <div class="dash-card">
                    <h3 class="dash-card-titulo">Km acumulado por equipe (por hora)</h3>
                    <div class="dash-chart-wrapper">
                        <canvas id="chartKmAcumulado"></canvas>
                    </div>
                </div>

                <!-- Grid: top atletas por período + top turnos -->
                <div class="dash-grid-2">
                    <div class="dash-card">
                        <h3 class="dash-card-titulo">Destaques por período do dia</h3>
                        <div class="dash-periodos">
                            <% periodos.forEach(p => {
                                const top = ds.topByPeriod[p];
                            %>
                            <div class="periodo-item <%= top ? '' : 'periodo-vazio' %>">
                                <div class="periodo-header">
                                    <span class="periodo-nome"><%= p %></span>
                                    <% if (p === 'Madrugada') { %><span class="periodo-hora">00h–06h</span>
                                    <% } else if (p === 'Manhã') { %><span class="periodo-hora">06h–12h</span>
                                    <% } else if (p === 'Tarde') { %><span class="periodo-hora">12h–18h</span>
                                    <% } else { %><span class="periodo-hora">18h–24h</span><% } %>
                                </div>
                                <% if (top) { %>
                                <div class="periodo-atleta">
                                    <span class="periodo-atleta-nome"><%= top.athlete_name %></span>
                                    <span class="periodo-equipe"><%= top.team_name %></span>
                                </div>
                                <div class="periodo-stats">
                                    <span><strong><%= Number(top.km_periodo).toFixed(1) %></strong> km</span>
                                    <span><strong><%= top.turnos_periodo %></strong> turno<%= top.turnos_periodo !== 1 ? 's' : '' %></span>
                                </div>
                                <% } else { %>
                                <span class="periodo-sem-dados">Sem dados ainda</span>
                                <% } %>
                            </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="dash-card">
                        <h3 class="dash-card-titulo">Top 5 maiores turnos</h3>
                        <% if (!ds.topShifts || ds.topShifts.length === 0) { %>
                        <p class="stats-vazio">Nenhum turno completo ainda.</p>
                        <% } else { %>
                        <ul class="dash-top-turnos">
                            <% ds.topShifts.forEach((s, i) => {
                                const dur = s.duration_seconds
                                    ? Math.floor(s.duration_seconds/3600)+'h '+(Math.floor((s.duration_seconds%3600)/60))+'min'
                                    : '—';
                            %>
                            <li class="dash-turno-item">
                                <span class="dash-turno-pos <%= i === 0 ? 'pos-1' : '' %>"><%= i + 1 %></span>
                                <div class="dash-turno-info">
                                    <span class="dash-turno-atleta"><%= s.athlete_name %></span>
                                    <span class="dash-turno-equipe"><%= s.team_name %> · <%= dur %></span>
                                </div>
                                <span class="dash-turno-km"><%= Number(s.distance).toFixed(1) %> km</span>
                            </li>
                            <% }) %>
                        </ul>
                        <% } %>
                    </div>
                </div>

                <!-- Gráfico: km por período do dia por equipe -->
                <div class="dash-card">
                    <h3 class="dash-card-titulo">Km por período do dia (por equipe)</h3>
                    <div class="dash-chart-wrapper dash-chart-sm">
                        <canvas id="chartKmPeriodo"></canvas>
                    </div>
                </div>

                <!-- Top por gênero + Top por equipe -->
                <div class="dash-grid-2">
                    <!-- Top por gênero -->
                    <div class="dash-card">
                        <h3 class="dash-card-titulo">Maiores corredores por gênero</h3>
                        <%
                            const generos = Object.keys(dashboardStats.topByGender || {}).sort();
                        %>
                        <% if (generos.length === 0) { %>
                        <p class="stats-vazio">Sem dados de gênero ainda.</p>
                        <% } else { %>
                        <% generos.forEach(genero => {
                            const lista = dashboardStats.topByGender[genero] || [];
                            const maxKm = lista.length ? Number(lista[0].total_km) : 1;
                        %>
                        <div class="genero-grupo">
                            <div class="genero-titulo"><%= genero %></div>
                            <% lista.forEach((a, i) => {
                                const pct = maxKm > 0 ? Math.round((Number(a.total_km) / maxKm) * 100) : 0;
                            %>
                            <div class="genero-atleta">
                                <span class="genero-pos <%= i === 0 ? 'pos-1' : '' %>"><%= i + 1 %></span>
                                <div class="genero-info">
                                    <div class="genero-nome-equipe">
                                        <span class="genero-nome"><%= a.athlete_name %></span>
                                        <span class="genero-equipe"><%= a.team_name %></span>
                                    </div>
                                    <div class="genero-barra-wrap">
                                        <div class="genero-barra" style="width:<%= pct %>%"></div>
                                    </div>
                                </div>
                                <span class="genero-km"><%= Number(a.total_km).toFixed(1) %> km</span>
                            </div>
                            <% }) %>
                        </div>
                        <% }) %>
                        <% } %>
                    </div>

                    <!-- Top por equipe -->
                    <div class="dash-card">
                        <h3 class="dash-card-titulo">Maiores corredores por equipe</h3>
                        <%
                            const atletasPorEq = {};
                            athleteStats.forEach(a => {
                                if (!atletasPorEq[a.team_id]) atletasPorEq[a.team_id] = { name: a.team_name, atletas: [] };
                                if (atletasPorEq[a.team_id].atletas.length < 3) atletasPorEq[a.team_id].atletas.push(a);
                            });
                        %>
                        <% Object.values(atletasPorEq).forEach(eq => {
                            const maxKm = eq.atletas.length ? Number(eq.atletas[0].total_km) : 1;
                        %>
                        <div class="genero-grupo">
                            <div class="genero-titulo"><%= eq.name %></div>
                            <% eq.atletas.forEach((a, i) => {
                                const pct = maxKm > 0 ? Math.round((Number(a.total_km) / maxKm) * 100) : 0;
                            %>
                            <div class="genero-atleta">
                                <span class="genero-pos <%= i === 0 ? 'pos-1' : '' %>"><%= i + 1 %></span>
                                <div class="genero-info">
                                    <span class="genero-nome"><%= a.athlete_name %></span>
                                    <div class="genero-barra-wrap">
                                        <div class="genero-barra" style="width:<%= pct %>%"></div>
                                    </div>
                                </div>
                                <span class="genero-km"><%= Number(a.total_km).toFixed(1) %> km</span>
                            </div>
                            <% }) %>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- TAB HISTÓRICO -->
            <div class="tab-conteudo tab-oculto" id="tab-historico">
                <% const shifts = historyEntries.filter(e => e.entry_type === 'shift_start'); %>
                <% if (shifts.length === 0) { %>
                <p class="stats-vazio">Nenhum turno registrado.</p>
                <% } else { %>
                <%
                    // Agrupa turnos por equipe (turnos de equipes diferentes acontecem em paralelo)
                    const turnosPorEquipe = {};
                    shifts.forEach(s => {
                        const key = s.team_id ?? s.team_name;
                        if (!turnosPorEquipe[key]) turnosPorEquipe[key] = { name: s.team_name, turnos: [] };
                        turnosPorEquipe[key].turnos.push(s);
                    });
                    // Dentro da equipe, ordem cronológica (mais antigo -> mais recente)
                    Object.values(turnosPorEquipe).forEach(eq =>
                        eq.turnos.sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp))
                    );
                %>
                <% Object.values(turnosPorEquipe).forEach(eq => { %>
                <div class="historico-equipe-bloco">
                <h3 class="historico-equipe-nome"><%= eq.name %></h3>
                <div class="tabela-wrapper">
                <table class="tabela-historico">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Atleta</th>
                            <th>Esteira</th>
                            <th>Km início</th>
                            <th>Km fim</th>
                            <th>Início</th>
                            <th>Fim</th>
                            <th>Auditor</th>
                            <% if (user_role === 'manager') { %><th>Editar</th><% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% eq.turnos.forEach((s, idx) => {
                            const tsFmt = s.timestamp ? new Date(s.timestamp).toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) : '—';
                            const endFmt = s.end_at ? new Date(s.end_at).toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) : '—';
                        %>
                        <tr>
                            <td class="col-num"><%= idx + 1 %></td>
                            <td>
                                <div class="cel-avatar">
                                    <span class="avatar-circle"></span>
                                    <%= s.athlete_name %>
                                </div>
                            </td>
                            <td><%= s.treadmill_number != null ? '#' + s.treadmill_number : '—' %></td>
                            <td><%= s.km_start != null ? Number(s.km_start).toFixed(1) : '—' %></td>
                            <td><%= s.km_end != null ? Number(s.km_end).toFixed(1) : '—' %></td>
                            <td><%= tsFmt %></td>
                            <td><%= endFmt %></td>
                            <td class="col-auditor">
                                <div class="cel-avatar">
                                    <span class="avatar-circle"></span>
                                    <%= s.auditor_name || '—' %>
                                </div>
                            </td>
                            <% if (user_role === 'manager') {
                                const dtIni = s.timestamp ? new Date(s.timestamp).toLocaleString('sv-SE').slice(0,16).replace(' ','T') : '';
                                const dtFim = s.end_at ? new Date(s.end_at).toLocaleString('sv-SE').slice(0,16).replace(' ','T') : '';
                            %>
                            <td class="col-editar">
                                <button type="button" class="btn-editar-turno" title="Editar turno"
                                    data-id="<%= s.shift_id %>"
                                    data-athlete="<%= s.athlete_id %>"
                                    data-team="<%= s.team_id %>"
                                    data-kmstart="<%= s.km_start != null ? s.km_start : '' %>"
                                    data-kmend="<%= s.km_end != null ? s.km_end : '' %>"
                                    data-start="<%= dtIni %>"
                                    data-end="<%= dtFim %>">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M12 20h9"></path>
                                        <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                                    </svg>
                                </button>
                            </td>
                            <% } %>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
                </div>
                </div>
                <% }) %>
                <% } %>
            </div>

            <!-- TAB EQUIPES -->
            <div class="tab-conteudo tab-oculto" id="tab-equipes">
                <%
                    const atletasPorEquipe = {};
                    athleteStats.forEach(a => {
                        if (!atletasPorEquipe[a.team_id]) atletasPorEquipe[a.team_id] = { name: a.team_name, atletas: [] };
                        atletasPorEquipe[a.team_id].atletas.push(a);
                    });
                %>
                <% Object.values(atletasPorEquipe).forEach(eq => { %>
                <div class="equipe-tab-bloco">
                    <h3 class="equipe-tab-nome"><%= eq.name %></h3>
                    <table class="tabela-atletas">
                        <thead>
                            <tr><th>#</th><th>Atleta</th><th>Km total</th><th>Turnos</th></tr>
                        </thead>
                        <tbody>
                            <% eq.atletas.forEach((a, idx) => { %>
                            <tr>
                                <td class="col-num"><%= idx + 1 %></td>
                                <td><%= a.athlete_name %></td>
                                <td><%= Number(a.total_km).toFixed(1) %></td>
                                <td><%= a.shift_count %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <% }) %>
                <% if (!athleteStats || athleteStats.length === 0) { %>
                <p class="stats-vazio">Nenhum atleta com dados.</p>
                <% } %>
            </div>

        </section>
    </main>

    <% if (user_role === 'manager') { %>
    <div class="tv-config-overlay" id="tvConfigOverlay"></div>
    <aside class="tv-config-drawer" id="tvConfigDrawer" aria-hidden="true">
        <div class="tv-config-topo">
            <div>
                <span class="tv-config-etiqueta">Experiência pública</span>
                <h2>Conteúdo para o público</h2>
                <p>Monte uma apresentação envolvente sem revelar o desempenho das equipes.</p>
            </div>
            <button type="button" class="tv-config-fechar" id="btnFecharModoTv" aria-label="Fechar">&times;</button>
        </div>

        <div class="tv-config-preview">
            <div class="tv-preview-tela">
                <span class="tv-preview-status">AO VIVO</span>
                <strong><%= evento.title %></strong>
                <div class="tv-preview-numeros">
                    <span><%= tvParticipantCount %> participantes</span>
                    <span><%= tvTotalKm.toFixed(1) %> km juntos</span>
                </div>
            </div>
        </div>

        <div class="tv-config-opcoes">
            <label class="tv-config-opcao">
                <span><strong>1. Abertura do evento</strong><small>Marca, local e tempo restante</small></span>
                <input type="checkbox" data-tv-opcao="abertura" checked>
                <i></i>
            </label>
            <label class="tv-config-opcao">
                <span><strong>2. Quilômetros juntos</strong><small>Total ao vivo, participantes e equivalência</small></span>
                <input type="checkbox" data-tv-opcao="coletivo" checked>
                <i></i>
            </label>
            <label class="tv-config-opcao">
                <span><strong>3. Ritmo e projeção</strong><small>Projeção de km ao fim, ritmo coletivo e progresso</small></span>
                <input type="checkbox" data-tv-opcao="ritmo" checked>
                <i></i>
            </label>
            <label class="tv-config-opcao">
                <span><strong>4. Mulheres e homens</strong><small>Prévia do total coletivo por gênero</small></span>
                <input type="checkbox" data-tv-opcao="genero" checked>
                <i></i>
            </label>
            <label class="tv-config-opcao">
                <span><strong>5. Pace médio</strong><small>Pace do período de 6h, atualizado a cada turno concluído</small></span>
                <input type="checkbox" data-tv-opcao="pace" checked>
                <i></i>
            </label>
            <label class="tv-config-opcao">
                <span><strong>6. Marca do dia</strong><small>Maior turno da competição, sem identificar atletas</small></span>
                <input type="checkbox" data-tv-opcao="recorde" checked>
                <i></i>
            </label>
            <label class="tv-config-opcao">
