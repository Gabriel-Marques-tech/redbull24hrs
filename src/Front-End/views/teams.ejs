<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auditor</title>
    <link rel="stylesheet" href="/css/global.css">
    <script src="/js/tema.js"></script>
    <link rel="stylesheet" href="/css/equipe.css">
</head>
<body>

    <div class="barra-gradiente"></div>
    <a href="/home" class="cancelar">
        <img src="/assets/competição/Seta.svg" alt="">
        Cancelar
    </a>

    <main>

        <aside class="etapas">
            <h3>Etapas</h3>
            <div class="etapa">
                <span>1</span>
                <p>Competição</p>
            </div>
            <div class="etapa ativa">
                <span>2</span>
                <p>Equipe</p>
            </div>
            <div class="etapa">
                <span>3</span>
                <p>Esteira</p>
            </div>
            <div class="etapa">
                <span>4</span>
                <p>Visão geral</p>
            </div>
        </aside>

    <div class="conteudo">

        <h2>Selecione a equipe</h2>
        <div class="opcoes-equipe">

            <% teams.forEach(team => { %>
            <div class="selecao-equipe" data-id="<%= team.id %>">

                <div class="selecao-topo" role="button" tabindex="0">
                    <span><%= team.name %></span>
                    <button class="selecao-seta" type="button" aria-label="Mostrar atletas da equipe">
                        <img src="/assets/competição/Seta.svg" alt="">
                    </button>
                </div>

                <div class="selecao-lista">
                    <% team.athletes.forEach(athlete => { %>
                    <p><%= athlete.name %></p>
                    <% }) %>
                </div>

            </div>
            <% }) %>

        </div>

        <div class="botoes botoes-fluxo-selecao">
            <button class="btn-voltar" onclick="window.location.href='/competition'">Anterior</button>
            <button class="btn-proximo" id="btn-proximo" disabled onclick="proximaEtapa()">Próximo</button>
        </div>
    </div>
    </main>
    <script>
    const eventId = <%= eventId %>;
    let teamIdSelecionado = null;
    const btnProximo = document.getElementById('btn-proximo');

    document.querySelectorAll('.selecao-equipe').forEach(card => {
        const topo = card.querySelector('.selecao-topo');
        const seta = card.querySelector('.selecao-seta');

        const selecionarEquipe = () => {
            document.querySelectorAll('.selecao-equipe').forEach(c => c.classList.remove('selecionada'));
            card.classList.add('selecionada');

            teamIdSelecionado = card.dataset.id;
            btnProximo.disabled = false;
        };

        topo.addEventListener('click', (event) => {
            if (event.target.closest('.selecao-seta')) return;
            selecionarEquipe();
        });

        topo.addEventListener('keydown', (event) => {
            if (event.key !== 'Enter' && event.key !== ' ') return;
            event.preventDefault();
            selecionarEquipe();
        });

        seta.addEventListener('click', (event) => {
            event.stopPropagation();
            const jaExpandida = card.classList.contains('expandida');

            document.querySelectorAll('.selecao-equipe').forEach(c => c.classList.remove('expandida'));
            if (!jaExpandida) card.classList.add('expandida');
        });
    });

    function proximaEtapa() {
        if (!teamIdSelecionado) return;
        window.location.href = `/treadmill?eventId=${eventId}&teamId=${teamIdSelecionado}`;
    }
    </script>
</body>
</html>
