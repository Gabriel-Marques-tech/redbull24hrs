<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <link href="https://fonts.googleapis.com/css?family=Inter:400,500,700&display=swap" rel="stylesheet">
    <link href="/css/login.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/global.css">
</head>

<body>

    <div class="login">
        <img src="/assets/logo-RB24h/logo.png" alt="logo">
        <div class="titulo">
            <h1>Faça seu login</h1><br>
            <p>24 horas conectando ideias, energias e<br> pessoas que fazem acontecer.</p>
        </div>
        <div class="form">
            <form id="login-form">
                <div class="role-selector">
                    <input type="radio" id="role-auditor" name="role" value="auditor" checked>
                    <label for="role-auditor">Auditor</label>
                    <input type="radio" id="role-manager" name="role" value="manager">
                    <label for="role-manager">Gerente</label>
                </div>
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="Insira seu email" required>
                <label for="senha" class="l1">Senha</label>
                <input type="password" name="senha" id="senha" placeholder="Insira sua senha" required><br>
                <p id="erro" style="color:red;display:none;margin:0;"></p>
                <button type="submit"><strong>Entrar</strong></button>
            </form>
        </div>
    </div>

    <script type="module" src="/js/login.js"></script>
</body>

</html>