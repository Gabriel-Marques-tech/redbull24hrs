<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Competição - Data e Horário</title>
    <link rel="icon" type="image/png" href="/assets/logo/logo-redrun.png">
    <link rel="apple-touch-icon" href="/assets/logo/logo-redrun.png">
    <link rel="stylesheet" href="/css/global.css">
    <script src="/js/tema.js"></script>
    <link rel="stylesheet" href="/css/equipe.css">
    <link rel="stylesheet" href="/css/gerente-data-horario.css">
</head>
<body>
    <div class="barra-gradiente"></div>

    <a href="/home" class="cancelar">
        <img src="/assets/competição/Seta.svg" alt="">
        Cancelar
    </a>

    <main>
        <aside class="etapas">
            <h3>Etapas</h3>
            <div class="etapa"><span>1</span><p>Local</p></div>
            <div class="etapa"><span>2</span><p>Imagem</p></div>
            <div class="etapa ativa"><span>3</span><p>Data e hora</p></div>
            <div class="etapa"><span>4</span><p>Equipes</p></div>
        </aside>

        <section class="conteudo conteudo-data-horario">
            <div class="formulario-data-horario">
                <h2>Defina uma data e um horário</h2>

                <div class="campos-data-horario">
                    <label class="grupo-data-horario" for="dataCompeticao">
                        <span>Data</span>
                        <div class="campo-data-horario">
                            <input id="dataCompeticao" name="dataCompeticao" type="date">
                        </div>
                    </label>

                    <label class="grupo-data-horario" for="horarioCompeticao">
                        <span>Horário</span>
                        <div class="campo-data-horario">
                            <input id="horarioCompeticao" name="horarioCompeticao" type="time">
                        </div>
                    </label>
                </div>
            </div>

            <div class="botoes botoes-data-horario">
                <button class="btn-voltar" type="button" onclick="window.location.href='/manager/create-event/image'">
                    Anterior
                </button>
                <button class="btn-proximo btn-proximo-data" type="button">Próximo</button>
            </div>
        </section>
    </main>

    <script src="/js/gerente-data-horario.js"></script>
</body>
</html>
