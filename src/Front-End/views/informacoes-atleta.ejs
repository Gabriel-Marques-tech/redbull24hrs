<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Informações do cadastro</title>
    <link rel="icon" type="image/png" href="/assets/logo/logo-redrun.png">
    <link rel="apple-touch-icon" href="/assets/logo/logo-redrun.png">
    <link rel="stylesheet" href="/css/global.css">
    <script src="/js/tema.js"></script>
    <link rel="stylesheet" href="/css/equipe.css">
    <link rel="stylesheet" href="/css/informacoes-atleta.css">
</head>
<body>
    <div class="barra-gradiente"></div>

    <a href="/manager/create-event/teams" class="cancelar" id="linkCancelar">
        <img src="/assets/competição/Seta.svg" alt="">
        Cancelar
    </a>

    <main>
        <aside class="etapas">
            <h3>Etapas</h3>
            <div class="etapa"><span>1</span><p>Local</p></div>
            <div class="etapa"><span>2</span><p>Data e hora</p></div>
            <div class="etapa ativa"><span>3</span><p>Equipes</p></div>
        </aside>

        <section class="conteudo-atleta">
            <span class="subetapa-atleta" id="subetapaCadastro">Cadastro de atleta</span>
            <div class="cabecalho-cadastro-pessoa">
                <h1 id="tituloCadastroPessoa">Informações do atleta</h1>
            </div>

            <form id="formAtleta">
                <div class="campo-foto-perfil" id="campoFotoPerfil">
                    <div class="foto-perfil-preview" id="fotoPerfilPreview">
                        <span>+</span>
                    </div>
                    <div>
                        <strong>Imagem de perfil</strong>
                        <p>Envie uma foto para identificar este cadastro.</p>
                        <button type="button" id="btnFotoPerfil">Escolher imagem</button>
                    </div>
                    <input id="fotoPerfilPessoa" type="file" accept="image/*">
                </div>

                <div class="campos-apoio-wrapper">
                    <div class="grid-cadastro-pessoa">
                        <label class="campo-cadastro-pessoa campo-cadastro-duplo">
                            <span>Nome <strong>*</strong></span>
                            <input id="nomeAtleta" type="text" required>
                        </label>

                        <label class="campo-cadastro-pessoa campo-cadastro-duplo" id="campoEmailPessoa">
                            <span>E-mail <strong>*</strong></span>
                            <input id="emailPessoa" type="email" placeholder="email@exemplo.com" required>
                        </label>

                        <label class="campo-cadastro-pessoa campo-cadastro-duplo campo-cpf-apoio" id="campoCpfApoio">
                            <span>CPF <strong>*</strong></span>
                            <input id="cpfApoio" type="text" inputmode="numeric" autocomplete="off" placeholder="000.000.000-00">
                        </label>

                        <label class="campo-cadastro-pessoa campo-cadastro-duplo escondido" id="campoRegistroAuditor">
                            <span>N° de registro <strong>*</strong></span>
                            <input id="registroAuditor" type="number" min="1" placeholder="Ex: 1042">
                        </label>
                    </div>

                    <div class="campos-acesso" id="camposAcesso">
                        <label class="campo-cadastro-pessoa">
                            <span>Senha <strong>*</strong></span>
                            <input id="senhaPessoa" type="password" placeholder="Senha de acesso">
                        </label>
                    </div>
                </div>

                <div class="campos-atleta" id="camposAtleta">
                    <label class="campo-cadastro-pessoa campo-data-atleta">
                        <span>Nascimento <strong>*</strong></span>
                        <input id="nascimentoAtleta" type="date" required>
                    </label>

                    <label class="campo-cadastro-pessoa">
                        <span>CPF</span>
                        <input id="cpfAtleta" type="text" placeholder="000.000.000-00">
                    </label>

                    <div class="seletores-atleta">
                        <select id="generoAtleta" required>
                            <option value="">Gênero *</option>
                            <option value="Feminino">Feminino</option>
                            <option value="Masculino">Masculino</option>
                            <option value="Outro">Outro</option>
                        </select>

                        <select id="cargoAtleta" required>
                            <option value="">Cargo *</option>
                            <option value="Atleta">Atleta</option>
                            <option value="Líder">Líder</option>
                        </select>
                    </div>
                </div>

                <button type="submit">Concluir</button>
            </form>
        </section>
    </main>

    <script src="/js/imageUtils.js"></script>
    <script src="/js/informacoes-atleta.js"></script>
</body>
</html>
