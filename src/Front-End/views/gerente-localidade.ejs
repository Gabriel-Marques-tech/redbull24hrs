<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Competição - Local</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/equipe.css">
    <link rel="stylesheet" href="/css/gerente-localidade.css">
</head>
<body>
    <div class="barra-gradiente"></div>

    <a href="/home" class="cancelar">
        <img src="/assets/competição/Seta.svg" alt="">
        Cancelar
    </a>

    <main>
        <aside class="etapas">
            <h3>Etapas</h3>
            <div class="etapa ativa"><span>1</span><p>Local</p></div>
            <div class="etapa"><span>2</span><p>Data e hora</p></div>
            <div class="etapa"><span>3</span><p>Equipes</p></div>
        </aside>

        <section class="conteudo conteudo-localidade">
            <div class="formulario-localidade">
                <h1>Selecione uma localidade</h1>

                <label for="nomeCompeticao">Nome da competição</label>
                <div class="campo-select">
                    <input id="nomeCompeticao" name="nomeCompeticao" type="text" autocomplete="off"
                           placeholder="Ex: Red Bull 24h São Paulo">
                </div>

                <label for="estado">Estado</label>
                <div class="campo-select" data-combo>
                    <input id="estado" name="estado" autocomplete="off"
                           placeholder="Digite ou selecione...">
                    <button type="button" class="combo-seta" tabindex="-1" aria-label="Abrir lista"></button>
                    <ul class="combo-lista" id="listaEstados"></ul>
                </div>

                <label for="cidade">Cidade</label>
                <div class="campo-select" data-combo>
                    <input id="cidade" name="cidade" autocomplete="off"
                           placeholder="Selecione um estado primeiro" disabled>
                    <button type="button" class="combo-seta" tabindex="-1" aria-label="Abrir lista"></button>
                    <ul class="combo-lista" id="listaCidades"></ul>
                </div>
            </div>

            <div class="botoes botoes-localidade">
                <button class="btn-proximo-localidade" type="button">Próximo</button>
            </div>
        </section>
    </main>

    <script src="/js/gerente-localidade.js"></script>
</body>
</html>
