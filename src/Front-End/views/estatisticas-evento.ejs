    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
    window.STARTED_AT    = '<%= startedAtIso %>';
    window.EVENTO_STATUS = '<%= evento.status %>';
    window.EVENTO_ID     = <%= evento.id %>;
    window.KM_BY_HOUR     = <%- JSON.stringify(dashboardStats.kmByHour) %>;
    window.TOP_BY_PERIOD  = <%- JSON.stringify(dashboardStats.topByPeriod) %>;
    window.TOP_BY_GENDER  = <%- JSON.stringify(dashboardStats.topByGender) %>;
    window.TEAM_STATS     = <%- JSON.stringify(teamStats) %>;
    window.ATHLETE_STATS  = <%- JSON.stringify(athleteStats) %>;
    window.TV_GENDER_TOTALS = window.TV_GENDER_TOTALS || null;
    window.TV_PACE_6H = window.TV_PACE_6H || null;
    window.TV_TOTAL_KM = <%= tvTotalKm %>;
    </script>
    <script>
    async function authFetch(url, options = {}) {
        const token = localStorage.getItem('accessToken');
        const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
        if (token) headers['Authorization'] = `Bearer ${token}`;
        let res = await fetch(url, { ...options, headers, credentials: 'include' });
        if (res.status === 401) {
            const r = await fetch('/auth/refresh', { method: 'POST', credentials: 'include' });
            if (!r.ok) { window.location.href = '/login'; return null; }
            const { accessToken } = await r.json();
            localStorage.setItem('accessToken', accessToken);
            headers['Authorization'] = `Bearer ${accessToken}`;
            res = await fetch(url, { ...options, headers, credentials: 'include' });
        }
        return res;
    }

    // Tabs
    document.querySelectorAll('.tab').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('tab-ativa'));
            document.querySelectorAll('.tab-conteudo').forEach(c => c.classList.add('tab-oculto'));
            btn.classList.add('tab-ativa');
            document.getElementById('tab-' + btn.dataset.tab).classList.remove('tab-oculto');
        });
    });

    // Countdown
    if (window.EVENTO_STATUS === 'in_progress' && window.STARTED_AT) {
        const duracao = 24 * 60 * 60 * 1000; // 24h em ms
        function atualizar() {
            const agora = Date.now();
            const fim = new Date(window.STARTED_AT).getTime() + duracao;
            const diff = fim - agora;
            const el = document.getElementById('countdown');
            if (!el) return;
            if (diff <= 0) { el.textContent = '00:00:00'; return; }
            const h = String(Math.floor(diff / 3600000)).padStart(2, '0');
            const m = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
            const s = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
            el.textContent = `${h}:${m}:${s}`;
        }
        atualizar();
        setInterval(atualizar, 1000);
    }

    // Export planilha
    async function exportarPlanilha(eventId) {
        const btn = document.querySelector('.btn-exportar');
        const original = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<img src="/assets/estatisticas/compartilhar.svg" alt="" class="btn-exportar-icone"> Gerando...';
        try {
            const res = await authFetch(`/export/events/${eventId}/shifts`);
            if (!res || !res.ok) {
                const err = await res?.json().catch(() => ({}));
                alert(err?.error || 'Erro ao exportar.');
                return;
            }
            const blob = await res.blob();
            const contentDisposition = res.headers.get('content-disposition') || '';
            const match = contentDisposition.match(/filename[^;=\n]*=["']?([^"';\n]+)["']?/);
            const filename = match ? match[1] : `evento-${eventId}.csv`;
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url; a.download = filename;
            document.body.appendChild(a); a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        } finally {
            btn.disabled = false;
            btn.innerHTML = original;
        }
    }

    // Gráficos (inicializados quando a aba dashboard é aberta pela primeira vez)
    let chartsInit = false;
    const TEAM_COLORS = ['#D2003C', '#0F0069', '#2e7d32', '#e65100', '#6a1b9a', '#00838f'];

    function initCharts() {
        if (chartsInit) return;
        chartsInit = true;

        const kmByHour  = window.KM_BY_HOUR  || {};
        const teamStats = window.TEAM_STATS   || [];

        // --- Gráfico 1: km acumulado por equipe (linha) ---
        const teamIds = Object.keys(kmByHour);
        const maxHour = teamIds.reduce((max, tid) => {
            const buckets = Object.keys(kmByHour[tid].buckets || {}).map(Number);
            return Math.max(max, buckets.length ? Math.max(...buckets) : 0);
        }, 0);
        const labels = Array.from({ length: Math.max(maxHour + 1, 1) }, (_, i) => `${i}h`);

        const datasetsAcum = teamIds.map((tid, i) => {
            const { name, buckets } = kmByHour[tid];
            let acc = 0;
            const data = labels.map((_, h) => {
                acc += buckets[h] || 0;
                return Math.round(acc * 10) / 10;
            });
            return {
                label: name,
                data,
                borderColor: TEAM_COLORS[i % TEAM_COLORS.length],
                backgroundColor: TEAM_COLORS[i % TEAM_COLORS.length] + '18',
                borderWidth: 2.5,
                pointRadius: 3,
                tension: 0.3,
                fill: false,
            };
        });

        new Chart(document.getElementById('chartKmAcumulado'), {
            type: 'line',
            data: { labels, datasets: datasetsAcum },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: { legend: { position: 'top' }, tooltip: { mode: 'index', intersect: false } },
                scales: {
                    x: { title: { display: true, text: 'Hora do evento' } },
                    y: { title: { display: true, text: 'Km acumulado' }, beginAtZero: true },
                },
            },
        });

        // --- Gráfico 2: km por período (barras agrupadas) ---
        const periodos = ['Madrugada', 'Manhã', 'Tarde', 'Noite'];
        const topByPeriod = window.TOP_BY_PERIOD || {};

        // agrupa km por equipe×período a partir de topByPeriod (top1 por período)
        // para o gráfico usamos teamStats total por período — mas só temos top1 do servidor
        // usamos o que há: km do destaque como referência visual
        const periodoDatasets = teamStats.map((team, i) => ({
            label: team.name,
            data: periodos.map(p => {
                const top = topByPeriod[p];
                return (top && top.team_name === team.name) ? Number(top.km_periodo) : 0;
            }),
            backgroundColor: TEAM_COLORS[i % TEAM_COLORS.length] + 'cc',
            borderColor: TEAM_COLORS[i % TEAM_COLORS.length],
            borderWidth: 1.5,
            borderRadius: 6,
        }));

        new Chart(document.getElementById('chartKmPeriodo'), {
            type: 'bar',
            data: { labels: periodos, datasets: periodoDatasets },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: { legend: { position: 'top' }, tooltip: { mode: 'index', intersect: false } },
                scales: {
                    x: { title: { display: true, text: 'Período' } },
                    y: { title: { display: true, text: 'Km (destaque do período)' }, beginAtZero: true },
                },
            },
        });
    }

    // Hook nos tabs para inicializar gráficos ao abrir dashboard
    document.querySelectorAll('.tab').forEach(btn => {
        btn.addEventListener('click', () => {
            if (btn.dataset.tab === 'dashboard') initCharts();
        });
    });

    // Finalizar
    async function finalizarCompetição(eventId) {
        if (!confirm('Finalizar a competição agora? Esta ação não pode ser desfeita.')) return;
        const btn = document.querySelector('.btn-finalizar');
        btn.disabled = true;
        btn.textContent = 'Finalizando...';
        const res = await authFetch(`/events/${eventId}/finish`, { method: 'PATCH' });
        if (res && res.ok) {
            window.location.href = '/home';
        } else {
            const err = await res?.json().catch(() => ({}));
            alert(err?.error || 'Erro ao finalizar competição.');
            btn.disabled = false;
            btn.textContent = 'Finalizar competição';
        }
    }
    </script>

    <% if (user_role === 'manager') { %>
    <script>
    (function configurarModoTv() {
        const drawer = document.getElementById('tvConfigDrawer');
        const overlay = document.getElementById('tvConfigOverlay');
        const modoTv = document.getElementById('modoTv');
        const btnAbrir = document.getElementById('btnAbrirModoTv');
        const btnFechar = document.getElementById('btnFecharModoTv');
        const btnIniciar = document.getElementById('btnIniciarModoTv');
        const btnSair = document.getElementById('btnSairModoTv');
        const opcoes = [...document.querySelectorAll('[data-tv-opcao]')];
        const tempoTela = document.getElementById('tvTempoTela');
        const btnAnterior = document.getElementById('tvAnterior');
        const btnProxima = document.getElementById('tvProxima');
        const btnPausar = document.getElementById('tvPausar');
        const indicadores = document.getElementById('tvIndicadores');
        const progresso = document.getElementById('tvProgresso');
        const chave = `modoTv:${window.EVENTO_ID}`;
        let telasAtivas = [];
        let telaAtual = 0;
        let temporizador = null;
        let pausado = false;

        if (!drawer || !overlay || !modoTv) return;

        function preferenciasAtuais() {
            return {
                telas: Object.fromEntries(opcoes.map(input => [input.dataset.tvOpcao, input.checked])),
                duracao: Number(tempoTela?.value || 12),
            };
        }

        function salvarPreferencias() {
            localStorage.setItem(chave, JSON.stringify(preferenciasAtuais()));
        }

        function carregarPreferencias() {
            const salvas = JSON.parse(localStorage.getItem(chave) || '{}');
            const telasSalvas = salvas.telas || salvas;
            opcoes.forEach(input => {
                if (typeof telasSalvas[input.dataset.tvOpcao] === 'boolean') {
                    input.checked = telasSalvas[input.dataset.tvOpcao];
                }
            });
            if (tempoTela && salvas.duracao) tempoTela.value = String(salvas.duracao);
        }

        function abrirConfiguracao() {
            drawer.classList.add('aberto');
            overlay.classList.add('aberto');
            drawer.setAttribute('aria-hidden', 'false');
        }

        function fecharConfiguracao() {
            drawer.classList.remove('aberto');
            overlay.classList.remove('aberto');
            drawer.setAttribute('aria-hidden', 'true');
        }

        function prepararTelas() {
            const preferencias = preferenciasAtuais();
            telasAtivas = [...modoTv.querySelectorAll('[data-tv-tela]')].filter(tela => {
                const ativa = preferencias.telas[tela.dataset.tvTela] !== false;
                tela.classList.toggle('tv-desativada', !ativa);
                return ativa;
            });

            if (telasAtivas.length === 0) {
                const abertura = modoTv.querySelector('[data-tv-tela="abertura"]');
                if (abertura) {
                    abertura.classList.remove('tv-desativada');
                    telasAtivas = [abertura];
                }
            }

            indicadores.innerHTML = telasAtivas
                .map((_, index) => `<button type="button" data-tv-indice="${index}" aria-label="Ir para tela ${index + 1}"></button>`)
                .join('');
            indicadores.querySelectorAll('button').forEach(botao => {
                botao.addEventListener('click', () => mostrarTela(Number(botao.dataset.tvIndice), true));
            });
        }

        function atualizarGenero() {
            const totais = window.TV_GENDER_TOTALS;
            if (!totais) return;

            const mulheres = Number(totais.mulheres);
            const homens = Number(totais.homens);
            const campoMulheres = document.getElementById('tvKmMulheres');
            const campoHomens = document.getElementById('tvKmHomens');
            const titulo = document.getElementById('tvTituloGenero');
            const pctMulheres = document.getElementById('tvPctMulheres');
            const pctHomensNumero = document.getElementById('tvPctHomensNumero');
            const barraMulheres = document.getElementById('tvBarraMulheres');
            const barraHomens = document.getElementById('tvBarraHomens');

            if (Number.isFinite(mulheres) && campoMulheres) {
                campoMulheres.innerHTML = `${mulheres.toFixed(1)} <small>km</small>`;
            }
            if (Number.isFinite(homens) && campoHomens) {
                campoHomens.innerHTML = `${homens.toFixed(1)} <small>km</small>`;
            }
            if (Number.isFinite(mulheres) && Number.isFinite(homens)) {
                const total = mulheres + homens;
                const percentualMulheres = total > 0 ? (mulheres / total) * 100 : 0;
                const percentualHomens = total > 0 ? (homens / total) * 100 : 0;
                if (pctMulheres) pctMulheres.textContent = `${percentualMulheres.toFixed(0)}%`;
                if (pctHomensNumero) pctHomensNumero.textContent = `${percentualHomens.toFixed(0)}%`;
                if (barraMulheres) barraMulheres.style.width = `${percentualMulheres}%`;
                if (barraHomens) barraHomens.style.width = `${percentualHomens}%`;
                if (titulo) {
                    const diferenca = Math.abs(mulheres - homens);
                    if (diferenca < 0.1) {
                        titulo.textContent = 'Lado a lado, a energia não para.';
                    } else if (mulheres > homens) {
                        titulo.textContent = 'Hoje, elas estão levando essa energia ainda mais longe.';
                    } else {
                        titulo.textContent = 'Mulheres e homens fazem essa energia acontecer.';
                    }
                }
            }
        }

        function atualizarPace() {
            const pace = window.TV_PACE_6H;
            if (!pace) return;

            const valor = document.getElementById('tvPaceMedio');
            const periodo = document.getElementById('tvPacePeriodo');

            if (pace.valor && valor) {
                valor.innerHTML = `${pace.valor}<small> min/km</small>`;
            }
            if (pace.periodo && periodo) {
                periodo.textContent = `Média coletiva do período ${pace.periodo}`;
            }
        }

        // Integração:
        // atualizarDadosModoTv({
        //   genero: { mulheres: 82.4, homens: 91 },
        //   pace: { valor: '05:42', periodo: '12h às 18h' }
        // });
        // Atualiza o total coletivo de km (tela "coletivo").
        function atualizarColetivo() {
            const total = window.TV_TOTAL_KM;
            const campo = document.getElementById('tvTotalKm');
            if (campo && Number.isFinite(Number(total))) {
                campo.innerHTML = `${Number(total).toFixed(1)} <small>km</small>`;
            }
        }

        window.atualizarDadosModoTv = function atualizarDadosModoTv(dados = {}) {
            if (dados.genero) window.TV_GENDER_TOTALS = dados.genero;
            if (dados.pace) window.TV_PACE_6H = dados.pace;
            if (dados.total_km != null) window.TV_TOTAL_KM = dados.total_km;
            atualizarColetivo();
            atualizarGenero();
            atualizarPace();
        };

        // Busca o resumo dinâmico do modo TV (total, gênero, pace) e aplica nas telas.
        // Em caso de falha de conexão, mantém os valores anteriores (não sobrescreve).
        async function carregarResumoTv() {
            try {
                const res = await authFetch(`/metrics/events/${window.EVENTO_ID}/tv`);
                if (!res || !res.ok) return;
                const dados = await res.json();
                window.atualizarDadosModoTv({
                    total_km: dados.total_km,
                    genero: dados.genero,
                    pace: dados.pace && dados.pace.valor ? dados.pace : undefined,
                });
            } catch (_) {
                // conexão perdida: mantém os últimos valores recebidos
            }
        }

        // Carrega ao montar e verifica a cada 60s se há novo turno concluído.
        carregarResumoTv();
        setInterval(carregarResumoTv, 60 * 1000);

        function reiniciarProgresso() {
            if (!progresso) return;
            progresso.style.animation = 'none';
            void progresso.offsetWidth;
            if (!pausado) {
                progresso.style.animation = `tvProgresso ${preferenciasAtuais().duracao}s linear forwards`;
            }
        }

        function agendarProxima() {
            clearTimeout(temporizador);
            if (pausado || telasAtivas.length < 2) return;
            temporizador = setTimeout(() => mostrarTela(telaAtual + 1), preferenciasAtuais().duracao * 1000);
        }

        function mostrarTela(indice, interacaoManual = false) {
            if (!telasAtivas.length) return;
            telaAtual = (indice + telasAtivas.length) % telasAtivas.length;
            modoTv.querySelectorAll('[data-tv-tela]').forEach(tela => tela.classList.remove('tv-ativa'));
            telasAtivas[telaAtual].classList.add('tv-ativa');
            indicadores.querySelectorAll('button').forEach((botao, index) => {
                botao.classList.toggle('ativo', index === telaAtual);
            });
            if (interacaoManual && pausado) {
                clearTimeout(temporizador);
            } else {
                reiniciarProgresso();
                agendarProxima();
            }
        }

        function alternarPausa() {
            pausado = !pausado;
            btnPausar.textContent = pausado ? 'Continuar' : 'Pausar';
            modoTv.classList.toggle('tv-pausado', pausado);
            if (pausado) {
                clearTimeout(temporizador);
                progresso.style.animationPlayState = 'paused';
            } else {
                reiniciarProgresso();
                agendarProxima();
            }
        }

        function sincronizarCronometroTv() {
            const origem = document.getElementById('countdown');
            const destino = document.getElementById('tvCountdown');
            if (origem && destino) destino.textContent = origem.textContent;
        }

        async function iniciarModoTv() {
            salvarPreferencias();
            prepararTelas();
            carregarResumoTv();
            atualizarColetivo();
            atualizarGenero();
            atualizarPace();
            sincronizarCronometroTv();
            fecharConfiguracao();
            modoTv.classList.add('ativo');
            modoTv.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
            pausado = false;
            btnPausar.textContent = 'Pausar';
            mostrarTela(0);

            try {
                if (modoTv.requestFullscreen && !document.fullscreenElement) {
                    await modoTv.requestFullscreen();
                }
            } catch (_) {}
        }

        async function sairModoTv() {
            clearTimeout(temporizador);
            modoTv.classList.remove('ativo');
            modoTv.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
            if (document.fullscreenElement) {
                try { await document.exitFullscreen(); } catch (_) {}
            }
        }

        carregarPreferencias();
        btnAbrir?.addEventListener('click', abrirConfiguracao);
        btnFechar.addEventListener('click', fecharConfiguracao);
        overlay.addEventListener('click', fecharConfiguracao);
        btnIniciar.addEventListener('click', iniciarModoTv);
        btnSair.addEventListener('click', sairModoTv);
        opcoes.forEach(input => input.addEventListener('change', salvarPreferencias));
        tempoTela?.addEventListener('change', salvarPreferencias);
        btnAnterior.addEventListener('click', () => mostrarTela(telaAtual - 1, true));
        btnProxima.addEventListener('click', () => mostrarTela(telaAtual + 1, true));
        btnPausar.addEventListener('click', alternarPausa);
        setInterval(sincronizarCronometroTv, 1000);
        document.addEventListener('keydown', event => {
            if (event.key === 'Escape' && modoTv.classList.contains('ativo')) sairModoTv();
        });
        document.addEventListener('fullscreenchange', () => {
            if (!document.fullscreenElement && modoTv.classList.contains('ativo')) sairModoTv();
        });

        const parametros = new URLSearchParams(window.location.search);
        if (parametros.get('modoTv') === 'config') {
            abrirConfiguracao();
            parametros.delete('modoTv');
            const novaBusca = parametros.toString();
            history.replaceState(null, '', window.location.pathname + (novaBusca ? `?${novaBusca}` : ''));
        }
    })();

    (function () {
        const overlay   = document.getElementById('modalEditarTurno');
        if (!overlay) return;
        const selAtleta = document.getElementById('editAtleta');
        const inId      = document.getElementById('editTurnoId');
        const inKmIni   = document.getElementById('editKmStart');
        const inKmFim   = document.getElementById('editKmEnd');
        const inIni     = document.getElementById('editInicio');
        const inFim     = document.getElementById('editFim');
        const erro      = document.getElementById('editErro');
        const athletes  = window.ATHLETE_STATS || [];

        function popularAtletas(teamId, selectedId) {
            selAtleta.innerHTML = '';
            athletes
                .filter(a => String(a.team_id) === String(teamId))
                .forEach(a => {
                    const opt = document.createElement('option');
                    opt.value = a.id;
                    opt.textContent = a.athlete_name;
                    if (String(a.id) === String(selectedId)) opt.selected = true;
                    selAtleta.appendChild(opt);
                });
        }

        function abrir(btn) {
            erro.style.display = 'none';
            inId.value    = btn.dataset.id;
            inKmIni.value = btn.dataset.kmstart;
            inKmFim.value = btn.dataset.kmend;
            inIni.value   = btn.dataset.start;
            inFim.value   = btn.dataset.end;
            popularAtletas(btn.dataset.team, btn.dataset.athlete);
            overlay.style.display = 'flex';
        }
        function fechar() { overlay.style.display = 'none'; }

        document.querySelectorAll('.btn-editar-turno').forEach(b =>
            b.addEventListener('click', () => abrir(b)));
        document.getElementById('btnCancelarEditarTurno').addEventListener('click', fechar);
        overlay.addEventListener('click', e => { if (e.target === overlay) fechar(); });

        document.getElementById('formEditarTurno').addEventListener('submit', async (e) => {
            e.preventDefault();
            erro.style.display = 'none';
            const kmStart = parseFloat(inKmIni.value);
            const kmEnd   = parseFloat(inKmFim.value);
            if (isNaN(kmStart) || isNaN(kmEnd) || kmEnd < kmStart) {
                erro.textContent = 'Km inválido: fim deve ser maior ou igual ao início.';
                erro.style.display = 'block';
                return;
            }
            const btn = document.getElementById('btnSalvarEditarTurno');
            btn.disabled = true;
            const res = await authFetch('/audit/shifts/' + inId.value, {
                method: 'PATCH',
                body: JSON.stringify({
                    athlete_id: selAtleta.value || null,
                    km_start: kmStart,
                    km_end: kmEnd,
                    start_at: inIni.value || null,
                    end_at: inFim.value || null,
                })
            });
            if (res && res.ok) {
                window.location.href = window.location.href;
            } else {
                const e2 = await res?.json().catch(() => ({}));
                erro.textContent = e2?.error || 'Erro ao salvar turno.';
                erro.style.display = 'block';
                btn.disabled = false;
            }
        });
    })();
    </script>
    <% } %>
</body>
</html>
